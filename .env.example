# Public origin used for shareable links and OG metadata.
# Defaults to https://window-fawn.vercel.app when unset.
# Set this to the production/custom domain once it is finalised.
NEXT_PUBLIC_APP_BASE_URL=https://window-fawn.vercel.app

# Optional branding overrides (defaults live in src/config/brand.ts).
# NEXT_PUBLIC_APP_NAME=window
# NEXT_PUBLIC_APP_DISPLAY_NAME=window
# NEXT_PUBLIC_APP_TAGLINE=都市の静けさを、そっと味わう時間。
# NEXT_PUBLIC_APP_DESCRIPTION=静かな都市の風景と環境音を眺めながら、気持ちを整えるWebアプリ。
